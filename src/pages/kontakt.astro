---
import Layout from '../layouts/Layout.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL;
const apiKey = import.meta.env.PUBLIC_API_KEY;
---

<Layout title="Kontakt – H2OPE" description="Napište nám, rádi poradíme s dalším krokem.">

  <div class="page-banner">
    <div class="container">
      <h1><span class="cs-only">Kontakt</span><span class="en-only">Contact</span></h1>
      <p><span class="cs-only">Napište nám, rádi poradíme s dalším krokem.</span><span class="en-only">Write to us, we'll be happy to help with the next step.</span></p>
    </div>
  </div>

  <section class="contact-section">
    <div class="container">
      <div class="contact-layout">

        <div class="contact-form-col">
          <h2 class="contact-heading"><span class="cs-only">Naše kontakty</span><span class="en-only">Our Contacts</span></h2>

          <form id="contactPageForm" class="contact-form">
            <div class="form-row-2">
              <div class="form-group">
                <label for="pageJmeno"><span class="cs-only">Jméno</span><span class="en-only">Name</span> <span class="req">*</span></label>
                <input type="text" id="pageJmeno" name="jmeno" required placeholder="Jan Novák" />
              </div>
              <div class="form-group">
                <label for="pageEmail">E-mail <span class="req">*</span></label>
                <input type="email" id="pageEmail" name="email" required placeholder="vas@email.cz" />
              </div>
            </div>
            <div class="form-group">
              <label for="pageTelefon"><span class="cs-only">Tel. číslo</span><span class="en-only">Phone</span></label>
              <input type="tel" id="pageTelefon" name="telefon" placeholder="+420 123 456 789" />
            </div>
            <div class="form-group">
              <label for="pageZprava"><span class="cs-only">Zpráva</span><span class="en-only">Message</span> <span class="req">*</span></label>
              <textarea id="pageZprava" name="zprava" rows="5" required placeholder="Váš dotaz nebo zpráva..."></textarea>
            </div>
            <div id="pageError" class="form-alert-error" hidden>
              <span class="cs-only">Nepodařilo se odeslat formulář. Zkuste to prosím znovu.</span>
              <span class="en-only">Failed to send the form. Please try again.</span>
            </div>
            <p class="consent-text">
              <span class="cs-only">Odesláním souhlasíte se zpracováním osobních údajů.</span>
              <span class="en-only">By submitting you agree to the processing of personal data.</span>
            </p>
            <button type="submit" class="btn btn-orange submit-btn" id="pageSubmit">
              <span id="pageSubmitLabel">
                <span class="cs-only">Odeslat</span>
                <span class="en-only">Send</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              </span>
              <span id="pageSubmitLoading" hidden>...</span>
            </button>
          </form>

          <div id="pageSuccess" class="form-success" hidden>
            <div class="success-icon">✓</div>
            <h3><span class="cs-only">Děkujeme!</span><span class="en-only">Thank you!</span></h3>
            <p><span class="cs-only">Vaše zpráva byla odeslána. Ozveme se vám brzy.</span><span class="en-only">Your message has been sent. We'll get back to you soon.</span></p>
          </div>
        </div>

        <div class="contact-info-col">
          <div class="info-card">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="info-body">
              <span class="info-label"><span class="cs-only">Náš E mail</span><span class="en-only">Our Email</span></span>
              <a href="mailto:info@h2ope.site" class="info-value">info@h2ope.site</a>
            </div>
          </div>
          <div class="info-card">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="info-body">
              <span class="info-label"><span class="cs-only">Naše sídlo</span><span class="en-only">Our Address</span></span>
              <span class="info-value"><span class="cs-only">Kaunicova 1812, 684 01, Slavkov u Brna</span><span class="en-only">Kaunicova 1812, 684 01, Slavkov u Brna</span></span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script define:vars={{ apiUrl, apiKey }}>
  const form = document.getElementById('contactPageForm');
  const submitBtn = document.getElementById('pageSubmit');
  const submitLabel = document.getElementById('pageSubmitLabel');
  const submitLoading = document.getElementById('pageSubmitLoading');
  const errorEl = document.getElementById('pageError');
  const successEl = document.getElementById('pageSuccess');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const f = e.currentTarget;

    submitBtn.disabled = true;
    submitLabel.hidden = true;
    submitLoading.hidden = false;
    errorEl.hidden = true;

    const data = {
      Jmeno: f.elements.namedItem('jmeno').value.trim(),
      Telefon: f.elements.namedItem('telefon').value.trim(),
      Email: f.elements.namedItem('email').value.trim(),
      Zprava: f.elements.namedItem('zprava').value.trim(),
    };

    try {
      const res = await fetch(apiUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'jv-api-key': apiKey,
        },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      form.style.display = 'none';
      successEl.hidden = false;
    } catch {
      errorEl.hidden = false;
      submitBtn.disabled = false;
      submitLabel.hidden = false;
      submitLoading.hidden = true;
    }
  });
</script>

<style>
  .contact-section {
    padding: 5rem 0 6rem;
    background: var(--white);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 4rem;
    align-items: start;
  }

  .contact-heading {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--blue);
    margin-bottom: 2rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .form-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--blue);
  }

  .req {
    color: var(--orange);
    font-weight: 700;
  }

  .form-group input,
  .form-group textarea {
    padding: 0.75rem 1rem;
    border: 1.5px solid rgba(26, 58, 92, 0.18);
    border-radius: 8px;
    font-family: var(--font);
    font-size: 0.95rem;
    color: var(--text);
    background: var(--white);
    transition: border-color 0.2s, box-shadow 0.2s;
    resize: vertical;
    outline: none;
    width: 100%;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--cyan);
    box-shadow: 0 0 0 3px rgba(0, 180, 216, 0.12);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(107, 114, 128, 0.55);
  }

  .consent-text {
    font-size: 0.82rem;
    color: var(--orange);
  }

  .submit-btn {
    align-self: flex-start;
    gap: 0.5rem;
  }

  .form-alert-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.88rem;
    color: #dc2626;
    line-height: 1.5;
  }

  .form-success {
    text-align: center;
    padding: 3rem 2rem;
  }

  .success-icon {
    width: 68px;
    height: 68px;
    background: linear-gradient(135deg, var(--cyan), var(--blue));
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.9rem;
    font-weight: 700;
    margin: 0 auto 1.25rem;
  }

  .form-success h3 {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--blue);
    margin-bottom: 0.5rem;
  }

  .form-success p {
    font-size: 1rem;
    color: var(--gray);
  }

  .contact-info-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 5rem;
  }

  .info-card {
    background: var(--white);
    border: 1.5px solid rgba(26, 58, 92, 0.1);
    border-radius: 16px;
    padding: 1.5rem 1.75rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    box-shadow: 0 4px 20px rgba(26, 58, 92, 0.06);
    transition: box-shadow 0.2s;
  }

  .info-card:hover {
    box-shadow: 0 8px 32px rgba(26, 58, 92, 0.1);
  }

  .info-icon {
    width: 48px;
    height: 48px;
    background: rgba(0, 180, 216, 0.1);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--cyan);
    flex-shrink: 0;
  }

  .info-body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .info-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--gray);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .info-value {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--blue);
  }

  a.info-value:hover {
    color: var(--cyan);
  }

  @media (max-width: 900px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
    .contact-info-col {
      padding-top: 0;
      flex-direction: row;
      flex-wrap: wrap;
    }
    .info-card {
      flex: 1;
      min-width: 240px;
    }
  }

  @media (max-width: 600px) {
    .form-row-2 {
      grid-template-columns: 1fr;
    }
    .contact-info-col {
      flex-direction: column;
    }
  }
</style>
