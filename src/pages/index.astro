    .flowgen-visual { order: -1; }
  }
  @media (max-width: 600px) {
    .mol-grid { grid-template-columns: 1fr; }
    .mol-cta-card { grid-column: span 1; flex-direction: column; }
    .steps-grid, .why-grid { grid-template-columns: 1fr; }
    .hero-stat-divider { display: none; }
    .aud-card { width: 290px; height: 280px; }
  }
</style>

<script>
  const audCards = Array.from(document.querySelectorAll('.aud-card'));
  const audDots  = Array.from(document.querySelectorAll('.aud-dot'));
  const audTabs  = Array.from(document.querySelectorAll('.aud-tab'));
  const total    = audCards.length;
  let current    = 0;

  function audGoTo(index) {
    current = ((index % total) + total) % total;
    audCards.forEach((card, i) => {
      let offset = i - current;
      if (offset > total / 2)  offset -= total;
      if (offset < -total / 2) offset += total;
      card.setAttribute('data-offset', String(offset));
    });
    audDots.forEach((dot, i) => dot.classList.toggle('active', i === current));
    const cat = audCards[current].dataset.category;
    audTabs.forEach(tab => tab.classList.toggle('active', tab.dataset.category === cat));
  }

  document.getElementById('audNext')?.addEventListener('click', () => audGoTo(current + 1));
  document.getElementById('audPrev')?.addEventListener('click', () => audGoTo(current - 1));
  audDots.forEach((dot, i) => dot.addEventListener('click', () => audGoTo(i)));
  audTabs.forEach(tab => tab.addEventListener('click', () => audGoTo(Number(tab.dataset.goto))));
  audCards.forEach((card, i) => {
    card.addEventListener('click', () => { if (card.dataset.offset !== '0') audGoTo(i); });
  });

  audGoTo(0);
</script>
