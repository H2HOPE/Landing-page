---
---

<div id="contactModal" class="modal-overlay" aria-hidden="true">
  <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
    <button class="modal-close" id="modalClose" aria-label="Zavřít">&times;</button>
    <div class="modal-header">
      <h2 id="modalTitle" class="modal-title">
        <span class="cs-only">Nezávazná konzultace</span>
        <span class="en-only">Free Consultation</span>
      </h2>
      <p class="modal-subtitle">
        <span class="cs-only">Vyplňte formulář a ozveme se vám do 24 hodin.</span>
        <span class="en-only">Fill in the form and we'll get back to you within 24 hours.</span>
      </p>
    </div>
    <form id="contactForm" class="modal-form">
      <div class="form-row">
        <div class="form-group">
          <label for="fieldJmeno"><span class="cs-only">Jméno</span><span class="en-only">Name</span></label>
          <input type="text" id="fieldJmeno" name="jmeno" required placeholder="Jan Novák" />
        </div>
        <div class="form-group">
          <label for="fieldTelefon"><span class="cs-only">Telefon</span><span class="en-only">Phone</span></label>
          <input type="tel" id="fieldTelefon" name="telefon" required placeholder="+420 123 456 789" />
        </div>
      </div>
      <div class="form-group">
        <label for="fieldEmail">Email</label>
        <input type="email" id="fieldEmail" name="email" required placeholder="vas@email.cz" />
      </div>
      <div class="form-group">
        <label for="fieldZprava"><span class="cs-only">Zpráva</span><span class="en-only">Message</span></label>
        <textarea id="fieldZprava" name="zprava" required rows="4" placeholder="Zajímá mě více informací o..."></textarea>
      </div>
      <div id="modalError" class="modal-alert-error" hidden>
        <span class="cs-only">Nepodařilo se odeslat formulář. Zkuste to prosím znovu.</span>
        <span class="en-only">Failed to send the form. Please try again.</span>
      </div>
      <button type="submit" class="btn btn-orange modal-submit" id="modalSubmit">
        <span id="submitLabel">
          <span class="cs-only">Odeslat</span>
          <span class="en-only">Send</span>
        </span>
        <span id="submitLoading" hidden>...</span>
      </button>
    </form>
    <div id="modalSuccess" class="modal-success" hidden>
      <div class="success-icon">✓</div>
      <h3>
        <span class="cs-only">Děkujeme!</span>
        <span class="en-only">Thank you!</span>
      </h3>
      <p>
        <span class="cs-only">Vaše zpráva byla odeslána. Ozveme se vám brzy.</span>
        <span class="en-only">Your message has been sent. We'll be in touch soon.</span>
      </p>
    </div>
  </div>
</div>

<script>
  function openContactModal() {
    const modal = document.getElementById('contactModal');
    if (!modal) return;
    const form = document.getElementById('contactForm') as HTMLFormElement | null;
    const success = document.getElementById('modalSuccess');
    const error = document.getElementById('modalError');
    const submitBtn = document.getElementById('modalSubmit') as HTMLButtonElement | null;
    const submitLabel = document.getElementById('submitLabel');
    const submitLoading = document.getElementById('submitLoading');
    if (form) { form.reset(); form.hidden = false; }
    if (success) success.hidden = true;
    if (error) error.hidden = true;
    if (submitBtn) submitBtn.disabled = false;
    if (submitLabel) submitLabel.hidden = false;
    if (submitLoading) submitLoading.hidden = true;
    modal.setAttribute('aria-hidden', 'false');
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeContactModal() {
    const modal = document.getElementById('contactModal');
    if (!modal) return;
    modal.setAttribute('aria-hidden', 'true');
    modal.classList.remove('open');
    document.body.style.overflow = '';
  }

  (window as any).openContactModal = openContactModal;

  document.getElementById('modalClose')?.addEventListener('click', closeContactModal);

  document.getElementById('contactModal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeContactModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeContactModal();
  });

  document.querySelectorAll('[data-open-modal="contact"]').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      openContactModal();
    });
  });

  const contactForm = document.getElementById('contactForm') as HTMLFormElement | null;
  contactForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const submitBtn = document.getElementById('modalSubmit') as HTMLButtonElement | null;
    const submitLabel = document.getElementById('submitLabel');
    const submitLoading = document.getElementById('submitLoading');
    const errorEl = document.getElementById('modalError');
    const successEl = document.getElementById('modalSuccess');

    if (submitBtn) submitBtn.disabled = true;
    if (submitLabel) submitLabel.hidden = true;
    if (submitLoading) submitLoading.hidden = false;
    if (errorEl) errorEl.hidden = true;

    const data = {
      jmeno: (form.elements.namedItem('jmeno') as HTMLInputElement).value.trim(),
      telefon: (form.elements.namedItem('telefon') as HTMLInputElement).value.trim(),
      email: (form.elements.namedItem('email') as HTMLInputElement).value.trim(),
      zprava: (form.elements.namedItem('zprava') as HTMLTextAreaElement).value.trim(),
    };

    try {
      const res = await fetch(import.meta.env.PUBLIC_API_URL, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Api-Key': import.meta.env.PUBLIC_API_KEY,
        },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      form.hidden = true;
      if (successEl) successEl.hidden = false;
    } catch {
      if (errorEl) errorEl.hidden = false;
      if (submitBtn) submitBtn.disabled = false;
      if (submitLabel) submitLabel.hidden = false;
      if (submitLoading) submitLoading.hidden = true;
    }
  });
</script>

<style>
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 25, 45, 0.8);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
    backdrop-filter: blur(4px);
  }

  .modal-overlay.open {
    opacity: 1;
    visibility: visible;
  }

  .modal-dialog {
    background: #fff;
    border-radius: 20px;
    width: 100%;
    max-width: 540px;
    max-height: 90vh;
    overflow-y: auto;
    padding: 2.5rem;
    position: relative;
    transform: scale(0.95) translateY(12px);
    transition: transform 0.25s ease;
    box-shadow: 0 30px 80px rgba(10, 25, 45, 0.35);
  }

  .modal-overlay.open .modal-dialog {
    transform: scale(1) translateY(0);
  }

  .modal-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    background: rgba(26, 58, 92, 0.07);
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.3rem;
    color: #1a3a5c;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    line-height: 1;
    font-family: inherit;
  }

  .modal-close:hover { background: rgba(26, 58, 92, 0.14); }

  .modal-header { margin-bottom: 1.75rem; padding-right: 2rem; }

  .modal-title {
    font-size: 1.6rem;
    font-weight: 800;
    color: #1a3a5c;
    margin-bottom: 0.4rem;
    line-height: 1.2;
  }

  .modal-subtitle {
    font-size: 0.95rem;
    color: #6b7280;
  }

  .modal-form { display: flex; flex-direction: column; gap: 1.1rem; }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group { display: flex; flex-direction: column; gap: 0.35rem; }

  .form-group label {
    font-size: 0.82rem;
    font-weight: 600;
    color: #1a3a5c;
    letter-spacing: 0.01em;
  }

  .form-group input,
  .form-group textarea {
    padding: 0.72rem 1rem;
    border: 1.5px solid rgba(26, 58, 92, 0.18);
    border-radius: 8px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.95rem;
    color: #1e293b;
    background: #fff;
    transition: border-color 0.2s, box-shadow 0.2s;
    resize: vertical;
    outline: none;
    width: 100%;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: #00b4d8;
    box-shadow: 0 0 0 3px rgba(0, 180, 216, 0.12);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(107, 114, 128, 0.55);
  }

  .modal-submit {
    width: 100%;
    justify-content: center;
    padding: 0.875rem;
    font-size: 1rem;
    margin-top: 0.25rem;
  }

  .modal-alert-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.88rem;
    color: #dc2626;
    line-height: 1.5;
  }

  .modal-success {
    text-align: center;
    padding: 1.5rem 0 0.5rem;
  }

  .success-icon {
    width: 68px;
    height: 68px;
    background: linear-gradient(135deg, #00b4d8, #1a3a5c);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.9rem;
    font-weight: 700;
    margin: 0 auto 1.25rem;
  }

  .modal-success h3 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #1a3a5c;
    margin-bottom: 0.5rem;
  }

  .modal-success p {
    font-size: 1rem;
    color: #6b7280;
  }

  @media (max-width: 600px) {
    .modal-dialog { padding: 2rem 1.5rem; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
